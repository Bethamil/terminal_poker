TERMINAL_POKER_IMAGE=ghcr.io/bethamil/terminal_poker:latest
APP_PORT=8080
CLIENT_ORIGIN=http://localhost:8080

# External Postgres
DATABASE_URL=postgresql://user:pass@your-postgres-host:5432/terminal_poker?schema=public

# App settings
ROOM_INACTIVITY_TTL_HOURS=24

# Redis is optional. Keep REDIS_MODE=none for a single backend instance.
REDIS_MODE=none
# REDIS_URL=redis://your-redis-host:6379
# REDIS_SENTINEL_URL=redis://sentinel-1:26379,redis://sentinel-2:26379,redis://sentinel-3:26379
# REDIS_SENTINEL_MASTER_NAME=mymaster
# REDIS_USERNAME=default
# REDIS_PASSWORD=secret
# REDIS_SENTINEL_USERNAME=default
# REDIS_SENTINEL_PASSWORD=secret

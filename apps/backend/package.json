{
  "name": "@terminal-poker/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cleanup:expired-rooms": "tsx src/scripts/cleanup-expired-rooms.ts",
    "dev": "tsx watch src/server.ts",
    "prisma:generate": "prisma generate",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@terminal-poker/shared-types": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "pg": "^8.16.3",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.8.1",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
